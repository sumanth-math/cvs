project_name = "platform-service"
environment  = "dev"
aws_region   = "us-east-1"

# Leave these empty to let Terraform create a starter VPC with two public subnets.
# For production, set these to existing networking resources and use private subnets
# with outbound access to ECR and AWS APIs.
vpc_id             = ""
alb_subnet_ids     = []
private_subnet_ids = []

managed_bucket_prefix = "my-company-platform-dev"

internal_alb                = true
# Narrow this for public starter deployments, for example ["203.0.113.10/32"].
allowed_ingress_cidr_blocks = ["0.0.0.0/0"]
image_tag                   = "latest"
desired_count               = 2
cpu_architecture            = "X86_64"
log_level                   = "info"

# Optional: allow callers to request aws:kms bucket encryption with these keys.
allowed_kms_key_arns = [
  # "arn:aws:kms:us-east-1:123456789012:key/00000000-0000-0000-0000-000000000000"
]

# Optional: GitHub webhook workflow automation.
# GitHub Actions can pass repository secrets PLATFORM_GITHUB_TOKEN and
# PLATFORM_GITHUB_WEBHOOK_SECRET into these sensitive variables during deploy.
# Warning: direct environment variables can be stored in Terraform state and ECS
# task definition history. The *_secret_arn fields remain supported for a
# stronger production setup.
github_token                    = ""
github_webhook_secret           = ""
github_token_secret_arn         = ""
github_webhook_secret_arn       = ""
github_secret_kms_key_arns      = []
github_auto_labels              = true
github_branch_name_pattern      = "^(feature|feat|fix|bugfix|hotfix|chore|docs|refactor|test|ci|build|release|dependabot)/[a-z0-9._-]+$"
deployment_summary_topic_arn    = ""

# Optional: record successful bucket provisioning API outputs in DynamoDB.
enable_api_records                 = true
api_records_table_name             = ""
api_records_point_in_time_recovery = true

# Optional: CloudWatch observability. Terraform creates a dashboard, ECS/ALB
# alarms, and an SNS topic by default. Email subscriptions require confirmation.
enable_observability                   = true
create_observability_sns_topic         = true
alarm_email_endpoints                  = []
alarm_notification_topic_arns          = []
alarm_cpu_threshold                    = 80
alarm_memory_threshold                 = 80
alarm_5xx_threshold                    = 5
alarm_unhealthy_host_threshold         = 1
alarm_target_response_time_seconds     = 2

# Optional: services aggregated by GET /v1/health-checks.
health_check_targets = [
  {
    name            = "github-api"
    url             = "https://api.github.com/meta"
    expected_status = 200
    timeout         = "2s"
  }
]

# Optional: developer portal catalog exposed by GET /v1/catalog.
portal_catalog_json = <<JSON
{
  "services": [
    {
      "id": "platform-api",
      "name": "Platform Self-Service API",
      "owner": "platform",
      "description": "Self-service API for developer cloud resource requests.",
      "repository": "https://github.com/sumanth-math/cvs",
      "runtime": "go",
      "lifecycle": "production",
      "tier": "internal",
      "environments": ["dev"]
    }
  ],
  "environments": [
    {
      "id": "dev",
      "name": "Development",
      "region": "us-east-1",
      "ecsCluster": "platform-service-dev"
    }
  ],
  "infrastructure": [
    {
      "id": "platform-service-dev-alb",
      "name": "Platform API ALB",
      "type": "alb",
      "provider": "aws",
      "environment": "dev",
      "region": "us-east-1",
      "owner": "platform"
    }
  ]
}
JSON

# Optional: have Terraform create a deploy role for GitHub Actions.
# If your account already has the GitHub OIDC provider, set github_oidc_provider_arn instead.
github_repository            = "your-org/your-repo"
github_branch                = "main"
create_github_oidc_provider  = false
github_oidc_provider_arn     = "arn:aws:iam::123456789012:oidc-provider/token.actions.githubusercontent.com"

tags = {
  Owner = "platform"
}
